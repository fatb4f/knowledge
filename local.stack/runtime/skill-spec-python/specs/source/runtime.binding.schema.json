{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fatb4f.github.io/kernel/schemas/control/runtime.binding.v1.schema.json",
  "title": "runtime.binding.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "binding_id",
    "host",
    "env_substrate",
    "operator_entry",
    "transport",
    "encoding"
  ],
  "properties": {
    "artifact_type": {
      "const": "runtime_binding"
    },
    "artifact_version": {
      "const": "v1"
    },
    "binding_id": {
      "type": "string",
      "minLength": 1
    },
    "host": {
      "type": "string",
      "enum": [
        "marimo"
      ]
    },
    "env_substrate": {
      "type": "string",
      "enum": [
        "uv"
      ]
    },
    "operator_entry": {
      "type": "string",
      "enum": [
        "just"
      ]
    },
    "transport": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "direct",
          "mcp",
          "acp"
        ]
      }
    },
    "encoding": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "json",
          "ndjson",
          "jsonl"
        ]
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
